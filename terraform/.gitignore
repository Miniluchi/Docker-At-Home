# Répertoires .terraform locaux (caches/plugins) — PAS le lock file.
# .terraform.lock.hcl est VOLONTAIREMENT versionné (hashes providers
# reproductibles, multi-plateforme via `terraform providers lock`).
.terraform/

# State (contient des secrets en clair)
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Fichiers de variables avec secrets.
# NB : un pattern « .tfvars » seul ne matche PAS « terraform.tfvars » -> on
# utilise « *.tfvars » (qui le couvre) tout en gardant l'exemple versionné.
*.tfvars
*.tfvars.json
!terraform.tfvars.example

# Override files (usage local)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Plans sauvegardés (peuvent contenir des secrets)
*.tfplan

# Fichiers générés (au cas où)
generated/
